DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/reviewfit
REDIS_URL=redis://localhost:6379
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI Provider 선택: groq (무료) | ollama (로컬) | openai (유료)
AI_PROVIDER=groq

# Groq (무료) - https://console.groq.com 에서 발급
GROQ_API_KEY=gsk_...

# Ollama (로컬 완전무료) - ollama pull llama3.2 후 사용
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (유료)
OPENAI_API_KEY=sk-...
